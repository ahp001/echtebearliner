{
  "expo": {
    "name": "ECHTE BÄRLINER",
    "slug": "echtebearliner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "echtebearliner",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
  "bundleIdentifier": "de.echtebearliner.app",
  "supportsTablet": true,
  "googleServicesFile": "./GoogleService-Info.plist",
  "infoPlist": {
    "ITSAppUsesNonExemptEncryption": false,
    "CFBundleDisplayName": "ECHTE BÄRLINER"
  }
},

    "android": {
      "package": "de.echtebearliner.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["NOTIFICATIONS"]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#000000"
        }
      ],
      [
  "expo-splash-screen",
  {
    "image": "./assets/images/loading/loading.jpeg",
    "resizeMode": "cover",
    "backgroundColor": "#000000",
    "dark": {
      "image": "./assets/images/loading/loading.jpeg",
      "backgroundColor": "#000000"
    }
  }
],
      "expo-font"
    ],

    "extra": {
      "router": {},
      "eas": {
        "projectId": "60187aba-cf6e-4b0d-a9cf-0c8d48d2a9a3"
      }
    },

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
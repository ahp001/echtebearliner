{
  "expo": {
    "name": "Echte Bärliner",
    "slug": "echtebearliner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "echtebearliner",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "de.echtebearliner.app",
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "Echte Bärliner"
      }
    },
    "android": {
      "package": "de.echtebearliner.app",
      "googleServicesFile": "./google-services.json",
      "icon": "./assets/images/icon.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["NOTIFICATIONS"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
  "expo-router",
  [
    "expo-splash-screen",
    {
      "backgroundColor": "#000000",
      "image": "./assets/images/icon.png",
      "resizeMode": "contain"
    }
  ],
  [
    "expo-notifications",
    {
      "icon": "./assets/images/icon.png",
      "color": "#000000"
    }
  ],
  "expo-font"
],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "60187aba-cf6e-4b0d-a9cf-0c8d48d2a9a3"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
   "runtimeVersion": "1.0.0",
   
    "updates": {
      "url": "https://u.expo.dev/60187aba-cf6e-4b0d-a9cf-0c8d48d2a9a3"
    }
  }
}